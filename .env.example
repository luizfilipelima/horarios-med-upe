# Supabase — copie este arquivo para .env e preencha com os valores do seu projeto
#
# Onde encontrar no painel do Supabase:
# 1. Acesse https://supabase.com/dashboard e abra seu projeto
# 2. Vá em Project Settings (ícone de engrenagem) > API
# 3. Em "Project URL" copie a URL e cole em VITE_SUPABASE_URL
# 4. Em "Project API keys" copie a chave "anon" / "public" (é um JWT longo que começa com eyJ...)
#    e cole em VITE_SUPABASE_ANON_KEY
#
# URL pública do site (para preview ao compartilhar links no WhatsApp etc.)
VITE_SITE_URL=https://seu-dominio.vercel.app
VITE_SUPABASE_URL=https://seu-projeto.supabase.co
VITE_SUPABASE_ANON_KEY=sua-chave-anonima-aqui

